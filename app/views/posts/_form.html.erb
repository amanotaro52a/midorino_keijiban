<%= form_with model: @post do |f| %>
  <%= render 'shared/error_messages', object: f.object %>
  <div class="mb-3">
  <%= f.label :image, class: "form-label" %>
  <div id="imagePickerZone"
       class="image-picker-zone"
       role="button"
       tabindex="0"
       aria-label="クリックまたはドラッグで画像を選択">
    <div id="pickerEmpty" class="picker-empty-state" style="<%= 'display:none;' if @post.image_url.present? %>">
      <i class="bi bi-image fs-1 text-secondary d-block mb-2" aria-hidden="true"></i>
      <p class="mb-1 fw-medium">クリックして画像を選択</p>
      <p class="text-secondary small mb-0">またはここにドラッグ＆ドロップ</p>
    </div>
    <% if @post.image_url.present? %>
      <div id="pickerCurrent" class="picker-current-wrap">
        <img src="<%= @post.image_url %>"
             alt="現在の画像"
             class="picker-thumb rounded-3">
        <div>
          <p class="text-secondary small mb-2">現在の画像</p>
          <button type="button" class="btn btn-sm btn-outline-secondary picker-change-btn">
            <i class="bi bi-arrow-repeat me-1" aria-hidden="true"></i>変更する
          </button>
        </div>
      </div>
    <% end %>
    <div id="pickerNewPreview" class="picker-new-wrap" style="display:none;">
      <img id="pickerNewThumb" src="" alt="新しい画像プレビュー" class="picker-thumb rounded-3">
      <div>
        <% if @post.image_url.present? %>
          <span class="badge text-bg-info mb-1">新しい画像</span>
        <% end %>
        <p id="pickerNewName" class="small fw-medium mb-0"></p>
        <p id="pickerNewSize" class="small text-secondary mb-2"></p>
        <button type="button" id="pickerClearBtn" class="btn btn-sm btn-outline-danger">
          <i class="bi bi-x me-1" aria-hidden="true"></i><span id="pickerClearLabel"></span>
        </button>
      </div>
    </div>
  </div>
  <div class="form-text">JPEG・PNG・WebP・GIF ／ 10MB以内</div>
  <%= f.file_field :image,
        id: "imageFileInput",
        class: "d-none",
        accept: "image/*",
        data: { has_current: @post.image_url.present? } %>
  </div>
  <div class="mb-3">
    <%= f.label :title, class: "form-label" %>
    <%= f.text_field :title, class: "form-control" %>
  </div>

  <%# ▼ Pl@ntNet連携: 植物名フィールド + 判別ボタン ▼ %>
  <div class="mb-3" data-controller="plant-identify">
    <%= f.label :plant_name, class: "form-label" %>

    <div class="d-flex gap-2 mb-2">
      <%= f.text_field :plant_name,
            class: "form-control",
            placeholder: "カタカナで入力",
            data: { "plant-identify-target": "plantName" },
            autocomplete: "off" %>

      <button type="button"
              class="btn btn-outline-success text-nowrap"
              data-plant-identify-target="identifyBtn"
              data-action="click->plant-identify#identify">
        <i class="bi bi-search me-1" aria-hidden="true"></i>判別する
      </button>
    </div>

    <div data-plant-identify-target="status"></div>
    <div data-plant-identify-target="suggestions" class="d-flex flex-wrap gap-2 mt-2"></div>
  </div>

  <div class="mb-4">
    <%= f.label :body, class: "form-label" %>
    <%= f.text_area :body, class: "form-control", rows: "10" %>
  </div>
  <div class="d-flex gap-2 justify-content-center">
    <%= f.submit t('buttons.save'), class: "btn btn-success" %>
  </div>
<% end %>