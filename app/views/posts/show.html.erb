<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-10 text-success-emphasis">
      <h1 class="fw-bold mb-4"><%= t('.title') %></h1>

      <article class="card shadow-sm rounded-4 overflow-hidden">
        <div class="row g-0">
          <div class="col-md-5">
            <%= image_tag @post.image.url, class: "img-fluid w-100 h-100", style: "object-fit: cover; min-height: 300px;" %>
          </div>
          <div class="col-md-7 d-flex flex-column text-success-emphasis">
            <div class="card-body p-4 d-flex flex-column h-100">
              <h3 class="fw-bold mb-2"><%= @post.title %></h3>
              <ul class="list-inline text-muted small mb-3">
                <li class="list-inline-item"><%= t('.created_by', user_name: @post.user.decorate.name) %></li>
                <li class="list-inline-item">・</li>
                <li class="list-inline-item"><%= l @post.created_at, format: :long %></li>
              </ul>

              <p class="mb-1"><strong><%= t('.plant_name') %>:</strong> <%= @post.plant_name %></p>
              <div class="mb-4"><%= simple_format(@post.body) %></div>

              <div class="d-flex justify-content-end gap-2 mt-auto flex-wrap">

                <%# 自分の投稿以外に表示 %>
                <% if show_post_actions?(@post) %>
                  <% if already_liked?(@post) %>
                    <%= button_to post_like_path(@post), method: :delete,
                        class: "btn btn-danger",
                        id: "button-unlike-#{@post.id}" do %>
                      <i class="bi bi-heart-fill"></i> <%= @post.likes_count %> <%= t('.like') %>
                    <% end %>
                  <% else %>
                    <%= button_to post_like_path(@post), method: :post,
                        class: "btn btn-outline-danger",
                        id: "button-like-#{@post.id}" do %>
                      <i class="bi bi-heart"></i> <%= @post.likes_count %> <%= t('.like') %>
                    <% end %>
                  <% end %>

                  <% if current_user.bookmark?(@post) %>
                    <%= button_to bookmark_path(current_user.bookmarks.find_by(post: @post)),
                        method: :delete,
                        class: "btn btn-warning",
                        id: "button-unbookmark-#{@post.id}" do %>
                      <i class="bi bi-bookmark-fill"></i> 保存済み
                    <% end %>
                  <% else %>
                    <%= button_to bookmarks_path(post_id: @post.id),
                        method: :post,
                        class: "btn btn-outline-warning",
                        id: "button-bookmark-#{@post.id}" do %>
                      <i class="bi bi-bookmark"></i> 保存する
                    <% end %>
                  <% end %>
                <% end %>

                <%# 編集・削除ボタン（自分の投稿にのみ表示） %>
                <% if current_user == @post.user %>
                  <%= link_to edit_post_path(@post), id: "button-edit-#{@post.id}", class: "btn btn-success" do %>
                    <i class="bi bi-pencil-fill"></i> <%= t('defaults.edit') %>
                  <% end %>
                  <%= link_to post_path(@post), id: "button-delete-#{@post.id}", class: "btn btn-danger",
                    data: { turbo_method: :delete, turbo_confirm: t('defaults.delete_confirm') } do %>
                    <i class="bi bi-trash-fill"></i> <%= t('defaults.delete') %>
                  <% end %>
                <% end %>
              </div>
            </div>
          </div>
        </div>
      </article>
    </div>
  </div>
</div>