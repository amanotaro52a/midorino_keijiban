<div class="col-sm-auto col-md-auto col-lg-3 mb-3">
  <div id="post-id-<%= post.id %>">
    <div class="card" style= "width: 20rem">
      <%= image_tag post.image_url, class: "card-img-top", width: "350", height: "200" %>
      <div class="card-content">
        <div class="d-flex">
          <h5 class="card-title">
            <%= link_to post.title, post_path(post), class: "stretched-link text-decoration-none", style: "margin-left: 1.0em;" %>
          </h5>
        </div>
        <ul class='ms-auto'>
          <li><i class="bi bi-person"></i><%= post.user.decorate.full_name %></li>
          <li><i class="bi bi-calendar"></i><%= l post.created_at, format: :short %></li>
          <li><strong><%= t('posts.index.plant_name') %>:</strong> <%= post.plant_name %></li>
        </ul>
      </div>
    </div>
  </div>
</div>
