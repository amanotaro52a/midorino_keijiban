<%= search_form_for q, url: url, method: :get, html: { class: 'row g-2 align-items-center' } do |f| %>

  <div class="col-12 col-sm-4">
    <%= f.search_field :title_or_body_cont, class: 'form-control', placeholder: t('search_form.placeholders.free_keyword') %>
  </div>

  <div class="col position-relative"
       data-controller="autocomplete"
       role="combobox"
       data-autocomplete-url-value="<%= plant_name_autocomplete_posts_path %>"
       data-autocomplete-min-length-value="1">
    <%= f.search_field :plant_name_cont,
          class: 'form-control',
          placeholder: t('search_form.placeholders.plant_name'),
          id: 'plant_name_search',
          autocomplete: 'off',
          data: { autocomplete_target: 'input' } %>
    <input type="hidden" data-autocomplete-target="hidden">
    <ul data-autocomplete-target="results"
        class="list-group position-absolute w-100"
        style="z-index: 1000; top: 100%;"></ul>
  </div>

  <div class="col-auto">
    <%= f.submit t('search_form.buttons.search'), class: 'btn btn-success' %>
  </div>
<% end %>
