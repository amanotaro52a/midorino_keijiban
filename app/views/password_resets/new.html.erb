<% content_for(:title, t('.title')) %>
<div class="container d-flex justify-content-center align-items-center min-vh-100">
  <div class="card shadow-sm rounded-4 text-success-emphasis" style="width: 100%; max-width: 500px;">
    <div class="card-body p-5">
      <h1 class="card-title h4 mb-4 fw-bold"><%= t('.title') %></h1>
      <%= form_with url: password_resets_path do |f| %>
        <div class="mb-4">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, class: "form-control" %>
        </div>
        <div class="d-grid">
          <%= f.submit t('.submit'), class: "btn btn-success w-100" %>
        </div>
      <% end %>
    </div>
  </div>
</div>